# ── 데이터베이스 연결 주소 ─────────────────────────────────
# 형식: postgresql+asyncpg://유저:비밀번호@호스트:포트/DB이름
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/persona_db

# ── JWT 토큰 서명용 비밀 키 ────────────────────────────────
# 아무 문자열이나 길게 입력 (실제 운영에선 랜덤 생성 권장)
# 생성법: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# ── JWT 토큰 만료 시간 (분 단위) ──────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Groq API 키 ───────────────────────────────────────────
# https://console.groq.com 에서 무료 발급 가능
GROQ_API_KEY=gsk_your-api-key-here

# ── 앱 기본 설정 ──────────────────────────────────────────
APP_NAME=AI 페르소나 챗봇 빌더
DEBUG=True
